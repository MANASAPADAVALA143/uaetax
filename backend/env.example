ANTHROPIC_API_KEY=your_claude_api_key_here

# Supabase: Dashboard → Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your database password. If the URI has no query string, append ?sslmode=require
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Supabase Auth + pgvector RAG
# Found in: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...  # service_role key (keep secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Railway deployment URL (no trailing slash)
# Example: https://gulftax-ai-production.up.railway.app
# Used by /api/health and n8n workflows (set GULFTAX_BACKEND_URL in n8n env too)
RAILWAY_BACKEND_URL=

# n8n webhook security
N8N_WEBHOOK_SECRET=your-webhook-hmac-secret-here
N8N_EINVOICING_WEBHOOK_URL=https://your-n8n.cloud/webhook/einvoicing
