# Copy to .env and adjust. Never commit .env.

# --- Local Postgres (Docker example from docs/BUILD_PLAN.md) ---
# docker run -d --name gulftax-db \
#   -e POSTGRES_DB=gulftax -e POSTGRES_USER=gulftax -e POSTGRES_PASSWORD=gulftax \
#   -p 5432:5432 postgres:15
DATABASE_URL=postgresql://gulftax:gulftax@localhost:5432/gulftax

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=

# --- n8n integration secrets (shared HMAC between FastAPI and n8n) ---
N8N_WEBHOOK_SECRET=your_secret_here
GULFTAX_N8N_SECRET=your_secret_here
N8N_EINVOICING_WEBHOOK_URL=https://your-n8n-instance/webhook/einvoicing
