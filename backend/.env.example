# GulfTax AI — Backend Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# --- Database (Supabase Postgres — production) ---
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.thwpeujhuqreceqvhpsb.supabase.co:5432/postgres

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Supabase ---
SUPABASE_URL=https://thwpeujhuqreceqvhpsb.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# --- n8n integration secrets (shared HMAC between FastAPI and n8n) ---
N8N_WEBHOOK_SECRET=change-this-to-a-strong-random-secret
N8N_EINVOICING_WEBHOOK_URL=https://your-n8n-instance/webhook/einvoicing

# --- Supabase Auth (for JWT verification) ---
# Option A (recommended): JWT secret from Supabase dashboard
#   Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
# Option B (fallback if no JWT secret): service role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
